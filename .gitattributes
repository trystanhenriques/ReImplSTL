# --------------------------------------------------------------------
# 1) Line endings: make the repo canonical on LF, while allowing
#    Windows checkouts to be CRLF if the user's Git core.autocrlf does that.
#    "text=auto" detects text files; "eol=lf" forces LF in the repo and checkout.
# --------------------------------------------------------------------
* text=auto eol=lf

# --------------------------------------------------------------------
# 2) Treat common C/C++ sources as text explicitly (good for clarity)
# --------------------------------------------------------------------
*.c     text eol=lf
*.cc    text eol=lf
*.cpp   text eol=lf
*.cxx   text eol=lf
*.h     text eol=lf
*.hh    text eol=lf
*.hpp   text eol=lf
*.hxx   text eol=lf
*.inl   text eol=lf
*.ipp   text eol=lf

# --------------------------------------------------------------------
# 3) Build/config scripts and docs (also text)
# --------------------------------------------------------------------
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.mk    text eol=lf
Makefile text eol=lf
*.sh    text eol=lf
*.py    text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf

# --------------------------------------------------------------------
# 4) Windows command scripts: usually should stay CRLF to run correctly in cmd.exe
#    (PowerShell is usually fine with LF, but many teams keep CRLF anyway.)
# --------------------------------------------------------------------
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# --------------------------------------------------------------------
# 5) Binary files: do not attempt text normalization, diffs, or merges
# --------------------------------------------------------------------
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.bmp  binary
*.ico  binary
*.pdf  binary

*.zip  binary
*.7z   binary
*.gz   binary
*.tar  binary

*.exe  binary
*.dll  binary
*.lib  binary
*.a    binary
*.so   binary
*.dylib binary
*.pdb  binary

# --------------------------------------------------------------------
# 6) Optional but useful: improve diffs for C++ (uses built-in "cpp" driver)
# --------------------------------------------------------------------
*.c   diff=cpp
*.cc  diff=cpp
*.cpp diff=cpp
*.cxx diff=cpp
*.h   diff=cpp
*.hpp diff=cpp
